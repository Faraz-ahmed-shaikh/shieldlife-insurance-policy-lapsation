    <dashboard enable-sort-zone-taborder='true' name='Retention &amp; Behaviour Analysis'>
      <style />
      <size maxheight='750' maxwidth='1600' minheight='750' minwidth='1600' preset-index='2' sizing-mode='fixed' />
      <datasources>
        <datasource name='Parameters' />
      </datasources>
      <datasource-dependencies datasource='Parameters'>
        <column caption='Choose Customer Segment' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Age Group&quot;'>
          <calculation class='tableau' formula='&quot;Age Group&quot;' />
          <members>
            <member value='&quot;Age Group&quot;' />
            <member value='&quot;Occupation&quot;' />
            <member value='&quot;Income Group&quot;' />
          </members>
        </column>
        <column caption='Choose Policy Segment' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Tenure Bucket&quot;'>
          <calculation class='tableau' formula='&quot;Tenure Bucket&quot;' />
          <members>
            <member value='&quot;Product&quot;' />
            <member value='&quot;Channel&quot;' />
            <member value='&quot;Premium Bucket&quot;' />
            <member value='&quot;Tenure Bucket&quot;' />
          </members>
        </column>
