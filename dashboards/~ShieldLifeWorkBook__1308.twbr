    <worksheet name='RB.KPI - Early Default Rate'>
      <table>
        <view>
          <datasources>
            <datasource caption='Policies' name='federated.15bhsvj123fiyr1ew3xop0fr8s9d' />
          </datasources>
          <datasource-dependencies datasource='federated.15bhsvj123fiyr1ew3xop0fr8s9d'>
            <column caption='Early Default Rate' datatype='real' name='[Calculation_0442574495961091]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='sum(IF [latest_status] = &apos;lapsed&apos; and [is_early_defaulted] = true then 1 else 0 end) / COUNT([policy_id])' />
            </column>
            <column caption='Is Early Defaulted' datatype='boolean' name='[is_early_defaulted]' role='dimension' type='nominal' />
