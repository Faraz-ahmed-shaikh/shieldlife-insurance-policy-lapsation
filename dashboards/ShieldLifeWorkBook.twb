      <aliases enabled='yes' />
      <column caption='Customer Renewal Rate' datatype='real' name='[Calculation_0279022060920835]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum(if [is_renewed_customer] = TRUE then 1 else 0 end) * 100.0 / count([customer_id])' />
      </column>
      <column caption='Total Active Customers' datatype='integer' name='[Calculation_0442574493450240]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [customer_latest_status] = &apos;Active&apos; then 1 else 0 end)' />
      </column>
      <column caption='Lapse Segment' datatype='string' name='[Calculation_0621795151462401]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;&#13;&#10;WHEN &quot;Age Group&quot; THEN [age_bucket]&#13;&#10;&#13;&#10;WHEN &quot;Occupation&quot; THEN [customer_occupation]&#13;&#10;&#13;&#10;WHEN &quot;City&quot; THEN [customer_city]&#13;&#10;&#13;&#10;WHEN &quot;Income Group&quot; THEN [customer_income_bracket]&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Lapse Rate for Segment' datatype='real' name='[Calculation_0621795152007170]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [customer_latest_status] = &quot;Lapsed&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)' />
      </column>
