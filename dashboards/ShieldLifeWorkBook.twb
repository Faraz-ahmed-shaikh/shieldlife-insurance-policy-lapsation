    <worksheet name='RB.Grace Period Lapse'>
      <table>
        <view>
          <datasources>
            <datasource caption='Policies' name='federated.15bhsvj123fiyr1ew3xop0fr8s9d' />
          </datasources>
          <datasource-dependencies datasource='federated.15bhsvj123fiyr1ew3xop0fr8s9d'>
            <column caption='Grace Period Lapse' datatype='real' name='[Calculation_0442574497222660]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [latest_status] = &apos;lapsed&apos; and [is_lapsed_after_grace] = true then 1 end) * 100.0 / count([policy_id])' />
            </column>
            <column caption='Is Lapsed After Grace' datatype='boolean' name='[is_lapsed_after_grace]' role='dimension' type='nominal' />
            <column caption='Latest Status' datatype='string' name='[latest_status]' role='dimension' type='nominal' />
            <column aggregation='CountD' caption='Policy Id' datatype='string' default-role='measure' default-type='quantitative' name='[policy_id]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0442574497222660]' derivation='User' name='[usr:Calculation_0442574497222660:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
