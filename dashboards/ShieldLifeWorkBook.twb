      <aliases enabled='yes' />
      <column caption='Persistency Ratio' datatype='real' name='[Calculation_0279022057062401]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [latest_status] = &apos;active&apos; THEN 1 ELSE 0 END) &#13;&#10;* 100.0 &#13;&#10;/ COUNT([policy_id])' />
      </column>
      <column caption='Policy Renewal Rate' datatype='real' name='[Calculation_0279022057545730]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.7227' />
      </column>
      <column caption='Total Lapsed Policies' datatype='integer' name='[Calculation_0442574495166466]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum(IF [latest_status] = &apos;lapsed&apos; then 1 else 0 end)' />
      </column>
      <column caption='Early Default Rate' datatype='real' name='[Calculation_0442574495961091]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum(IF [latest_status] = &apos;lapsed&apos; and [is_early_defaulted] = true then 1 else 0 end) / COUNT([policy_id])' />
      </column>
      <column caption='Grace Period Lapse' datatype='real' name='[Calculation_0442574497222660]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [latest_status] = &apos;lapsed&apos; and [is_lapsed_after_grace] = true then 1 end) * 100.0 / count([policy_id])' />
      </column>
      <column caption='Lapse Rate' datatype='real' name='[Calculation_0621795154886659]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [latest_status] = &apos;lapsed&apos; THEN 1 ELSE 0 END) &#13;&#10;* 100.0 &#13;&#10;/ COUNT([policy_id])' />
      </column>
      <column caption='Lapse Rate by Product Segment' datatype='string' name='[Calculation_0621795159113732]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;&#13;&#10;WHEN &quot;Product&quot; THEN [product_name]&#13;&#10;&#13;&#10;WHEN &quot;Channel&quot; THEN [channel_name]&#13;&#10;&#13;&#10;WHEN &quot;Premium Bucket&quot; THEN [premium_bucket]&#13;&#10;&#13;&#10;WHEN &quot;Tenure Bucket&quot; THEN [tenure_bucket]&#13;&#10;&#13;&#10;WHEN &quot;Product&quot; THEN [product_name]&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Early Default Distribution' datatype='string' name='[Calculation_0621795162947589]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_early_defaulted] = TRUE THEN &apos;Early Defaulted&apos; ELSE &apos;Not Early Default&apos; END' />
      </column>
      <column caption='Total Acquistition at Risk' datatype='real' name='[Calculation_0621795176882182]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [latest_status] = &apos;lapsed&apos; THEN&#13;&#10;    [cost_spent]&#13;&#10;END&#13;&#10;) / 10000000' />
      </column>
      <column caption='Total Unrealised Premium' datatype='real' name='[Calculation_0621795180630023]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([unrealised_premium_value]) / 10000000' />
      </column>
      <column caption='Total Expected Premium' datatype='real' name='[Calculation_0621795182546952]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([expected_premium_value]) / 10000000' />
      </column>
      <column caption='Remaining Collectable Premium' datatype='real' name='[Calculation_0621795183353865]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([expected_premium_value])&#13;&#10;-&#13;&#10;SUM([total_premium_received])&#13;&#10;-&#13;&#10;SUM([unrealised_premium_value]))&#13;&#10;/ 10000000' />
      </column>
      <column caption='Calculation1' datatype='real' name='[Calculation_0621795213807627]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &apos;Unrealised Premium&apos; THEN sum([unrealised_premium_value]) &#13;&#10;ELSE sum([total_premium_received])' />
      </column>
      <column caption='Product Measure' datatype='real' name='[Calculation_0621795214204940]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &apos;Unrealised Premium&apos; THEN SUM([unrealised_premium_value])&#13;&#10;ELSE  SUM([total_premium_received])&#13;&#10;END' />
      </column>
      <column caption='zero' datatype='integer' name='[Calculation_0771053560201216]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='acquisition_loss' datatype='real' name='[Calculation_0771053569114114]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [latest_status] = &apos;lapsed&apos; then [cost_spent] else 0 END)' />
      </column>
