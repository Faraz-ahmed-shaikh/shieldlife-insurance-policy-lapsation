            <column caption='Customer Latest Status' datatype='string' name='[customer_latest_status]' role='dimension' type='nominal' />
            <column caption='Customer Occupation' datatype='string' name='[customer_occupation]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0621795151462401]' derivation='None' name='[none:Calculation_0621795151462401:nk]' pivot='key' type='nominal' />
