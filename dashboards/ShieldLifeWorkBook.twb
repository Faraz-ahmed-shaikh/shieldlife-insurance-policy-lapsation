            <column caption='Lapse Rate' datatype='real' name='[Calculation_0621795154886659]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [latest_status] = &apos;lapsed&apos; THEN 1 ELSE 0 END) &#13;&#10;* 100.0 &#13;&#10;/ COUNT([policy_id])' />
            </column>
            <column caption='Lapse Rate by Product Segment' datatype='string' name='[Calculation_0621795159113732]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;&#13;&#10;WHEN &quot;Product&quot; THEN [product_name]&#13;&#10;&#13;&#10;WHEN &quot;Channel&quot; THEN [channel_name]&#13;&#10;&#13;&#10;WHEN &quot;Premium Bucket&quot; THEN [premium_bucket]&#13;&#10;&#13;&#10;WHEN &quot;Tenure Bucket&quot; THEN [tenure_bucket]&#13;&#10;&#13;&#10;WHEN &quot;Product&quot; THEN [product_name]&#13;&#10;&#13;&#10;END' />
