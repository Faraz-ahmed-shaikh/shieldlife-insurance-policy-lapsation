              <text column='[federated.15bhsvj123fiyr1ew3xop0fr8s9d].[usr:Calculation_0442574497222660:qk]' />
            </encodings>
            <customized-label>
              <formatted-text>
                <run bold='true' fontcolor='#ffffff' fontname='Trebuchet MS' fontsize='12'><![CDATA[<[federated.15bhsvj123fiyr1ew3xop0fr8s9d].[usr:Calculation_0442574497222660:qk]>%]]></run>
                <run>Æ&#10;</run>
